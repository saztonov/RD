# =============================================================================
# Remote OCR Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Binding (Docker)
# -----------------------------------------------------------------------------
# Address to bind the server (default: 127.0.0.1 for localhost only)
# Use 0.0.0.0 only behind a reverse proxy (nginx)
REMOTE_OCR_BIND_ADDR=127.0.0.1

# Port to expose (default: 18000)
# Change if port is already in use
REMOTE_OCR_PORT=18000

# -----------------------------------------------------------------------------
# Supabase Database
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=rd1

# -----------------------------------------------------------------------------
# OCR Engines (at least one required)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_key
DATALAB_API_KEY=your_datalab_key

# -----------------------------------------------------------------------------
# API Security (optional but recommended for production)
# -----------------------------------------------------------------------------
# If set, all API requests must include X-API-Key header
REMOTE_OCR_API_KEY=

# -----------------------------------------------------------------------------
# Client Configuration (for desktop app)
# -----------------------------------------------------------------------------
# URL of the remote OCR server
# Local dev: http://localhost:18000
# Production: https://your-domain.com
REMOTE_OCR_BASE_URL=http://localhost:18000

# -----------------------------------------------------------------------------
# Redis (only needed if running manually without Docker)
# -----------------------------------------------------------------------------
# Docker uses internal redis://redis:6379/0 automatically
REDIS_URL=redis://localhost:6379/0
