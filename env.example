# ===========================================
# DESKTOP CLIENT
# ===========================================
# URL сервера OCR (для локального Docker: http://localhost:18000)
REMOTE_OCR_BASE_URL=http://localhost:18000
# API ключ (опционально, для аутентификации)
REMOTE_OCR_API_KEY=

# ===========================================
# SUPABASE (обязательно)
# ===========================================
# Хранение jobs, tree_nodes, node_files
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGci...YOUR_ANON_KEY

# ===========================================
# R2 STORAGE (обязательно)
# ===========================================
# Cloudflare R2 для PDF, блоков и результатов
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name

# ===========================================
# OCR BACKENDS (минимум один)
# ===========================================
# OpenRouter (GPT-4V, Claude Vision)
OPENROUTER_API_KEY=sk-or-v1-...

# Datalab (marker-v3 для текста/таблиц)
DATALAB_API_KEY=

# ===========================================
# DOCKER SETTINGS (опционально)
# ===========================================
# Bind address (127.0.0.1 = только localhost, 0.0.0.0 = все интерфейсы)
REMOTE_OCR_BIND_ADDR=127.0.0.1
# Внешний порт
REMOTE_OCR_PORT=18000

# Redis (автоматически устанавливается в docker-compose)
# REDIS_URL=redis://redis:6379/0
